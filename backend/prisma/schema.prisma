datasource db {
    provider = "postgresql"
    // url      = env("DATABASE_URL")
}

generator client {
    provider        = "prisma-client-js"
    previewFeatures = []
}

model User {
    id        String    @id @default(cuid())
    email     String    @unique
    password  String
    createdAt DateTime  @default(now())
    workouts  Workout[]
}

model Workout {
    id        String   @id @default(cuid())
    userId    String
    name      String
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id])
}
